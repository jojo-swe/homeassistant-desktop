{
  "name": "homeassistant-desktop",
  "repository": {
    "type": "git",
    "url": "https://github.com/jojo-swe/homeassistant-desktop"
  },
  "version": "2.1.0",
  "description": "Desktop App (Windows / macOS / Linux) for Home Assistant built with Electron",
  "author": {
    "name": "jojo-swe",
    "email": "jojo-swe@users.noreply.github.com"
  },
  "license": "Apache-2.0",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build && electron-builder build --publish never",
    "build:dir": "electron-vite build",
    "build-local-mac": "electron-vite build && electron-builder build --mac --x64 --publish never",
    "build-local-mac-arm": "electron-vite build && electron-builder build --mac --arm64 --publish never",
    "build-local-linux": "electron-vite build && electron-builder build --linux appimage --x64 --publish never",
    "build-local-linux-arm": "electron-vite build && electron-builder build --linux rpm --arm64 --publish never",
    "build-local-win": "electron-vite build && electron-builder build --win --x64 --publish never",
    "build-local-win-arm": "electron-vite build && electron-builder build --win --arm64 --publish never",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "electron-vite build && playwright test",
    "test:e2e:only": "playwright test",
    "typecheck": "svelte-check && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate-icons": "node scripts/generate-icons.cjs"
  },
  "dependencies": {
    "bonjour-service": "^1.0.14",
    "electron-log": "^4.4.8",
    "electron-store": "^8.1.0",
    "electron-traywindow-positioner": "^1.1.1",
    "electron-updater": "^6.8.9",
    "systeminformation": "^5.31.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^3.2.7",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "sharp": "^0.35.3",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  },
  "engines": {
    "node": ">= 20"
  },
  "build": {
    "appId": "io.github.jojo_swe.homeassistant-desktop",
    "artifactName": "${productName}-v${version}-${os}-${arch}.${ext}",
    "productName": "Home Assistant Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "assets/**/*",
      "build/**/*",
      "io.github.jojo_swe.homeassistant-desktop.*"
    ],
    "publish": {
      "provider": "github",
      "owner": "jojo-swe",
      "repo": "homeassistant-desktop"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "zip",
        "dmg"
      ],
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "target": [
        "nsis",
        "zip",
        "portable"
      ],
      "signtoolOptions": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerLanguages": [
        "en_US"
      ],
      "language": "1033"
    },
    "portable": {
      "artifactName": "${productName}-v${version}-${os}-${arch}-portable.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Network"
    },
    "deb": {
      "depends": [
        "libayatana-appindicator3-1"
      ]
    }
  }
}
